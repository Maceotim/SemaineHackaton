    "df_normalize_R.to_csv('mes_donnees_normalisées_R.csv', sep=';', index=False, encoding='utf-8-sig') #exportation des données normalisées en csv\n",
    "df_normalize_G.to_csv('mes_donnees_normalisées_G.csv', sep=';', index=False, encoding='utf-8-sig') #exportation des données normalisées en csv"
